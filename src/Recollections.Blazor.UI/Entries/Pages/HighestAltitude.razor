@page "/highest-altitude"
@inherits UserStateAuthenticatedComponentBase

<DocumentTitle Value="Highest altitude" />
<TemplateContent Name="MobileTitle">Highest altitude</TemplateContent>

@if (!IsLoading && Items.Count == 0)
{
    <Alert Mode="@AlertMode.Warning" Message="No entries with altitude yet..." />
}
else
{
    <Timeline Data="@Items" EntryTitleSelector="FormatEntryTitle" />
}
