@page "/search"
@inherits UserStateAuthenticatedComponentBase

<DocumentTitle Value="Search" />

<div class="card-list">
    <form @onsubmit="@(() => { Navigator.OpenSearch(SearchText, SearchType); StateHasChanged(); })">
        <div class="row gx-2 my-4">
            <div class="col-md col-sm-12">
                <input @ref="SearchInput" class="form-control" type="text" placeholder="Search phrase..." @bind="SearchText" />
            </div>
            <div class="col-md-auto col-sm-12 mt-2 mt-md-0">
                <div class="btn-group d-flex" role="group" aria-label="Search type">
                    <button type="button" class="btn @(IsEntryType ? "btn-secondary" : "btn-outline-secondary")" @onclick="OpenEntrySearch">
                        Entries
                    </button>
                    <button type="button" class="btn @(IsStoryType ? "btn-secondary" : "btn-outline-secondary")" @onclick="OpenStorySearch">
                        Stories
                    </button>
                </div>
            </div>
            <div class="col-md-auto col-sm-12 mt-2 mt-md-0">
                <button class="btn btn-primary d-block w-100">
                    <Icon Identifier="search" />
                    Search
                </button>
            </div>
        </div>
    </form>

    <div class="row">
        @if (IsEntryType)
        {
            <ListView Items="@EntryItems" IsLoading="@(EntryItems.Count == 0 && IsLoading)" EmptyMessage="@EmptyMessage" EmptyColWrapper="true" Context="entry">
                <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3 mb-4">
                    <EntryCard Model="entry" CardCssClass="h-100" OnCardClick="() => Navigator.OpenEntryDetail(entry.Id)" />
                </div>

                @if (EntryItems.IndexOf(entry) == EntryItems.Count - 3 && HasMore)
                {
                    <AutoloadNext Intersected="@LoadMoreAsync" />
                }
            </ListView>
        }
        else
        {
            <ListView Items="@StoryItems" IsLoading="@(StoryItems.Count == 0 && IsLoading)" EmptyMessage="@EmptyMessage" EmptyColWrapper="true" Context="story">
                <div class="col-sm-12 col-md-6 col-lg-4 col-xl-3 mb-4">
                    <StoryCard Model="story" CardCssClass="h-100" OnCardClick="() => Navigator.OpenStoryDetail(story.Id)" />
                </div>

                @if (StoryItems.IndexOf(story) == StoryItems.Count - 3 && HasMore)
                {
                    <AutoloadNext Intersected="@LoadMoreAsync" />
                }
            </ListView>
        }
    </div>
</div>