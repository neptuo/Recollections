@page "/beings/{BeingId}"
@inherits UserStateComponentBase

<DocumentTitle Value="@(Model?.Name ?? "Being...")" />

@if (Model != null)
{

    <CascadingValue Value="@Model">
        <PermissionContainer State="@Permissions">
            <ActionMenu>
                <ItemGroup Text="@Model.Name">
                    <PermissionView Request="PermissionRequest.Owner">
                        <ShareButton Owner="@Owner" BeingId="@Model.Id" Layout="ButtonLayout.Item" />
                    </PermissionView>
                    <ShareLinkButton Layout="ButtonLayout.Item" />
                    <PermissionView Request="PermissionRequest.Owner">
                        @if (Model.Id != Model.UserId)
                        {
                            <Item Icon="trash-alt" Text="Delete Being" OnClick="DeleteAsync" CssClass="text-danger" Title="Delete Being" />
                        }
                    </PermissionView>
                </ItemGroup>
            </ActionMenu>

            <div class="my-sm-3">
                <InlineTitleEdit Value="@Model.Name" ValueChanged="@(async value => await SaveNameAsync(value))" />
                <h2 class="icon">
                    <InlineLink Value="@Model.Icon" PlaceHolder="user" OnClick="@(() => IconPicker.Show())">
                        <ValueContent Context="identifier">
                            <Icon Identifier="@identifier" />
                        </ValueContent>
                    </InlineLink>
                </h2>
                <UserInformation Owner="@Owner" />
                <div class="gps">
                    <MapToggle DialogTitle="@($"{Model.Name}: Map")" Text="@(Markers.Count == 0 ? "No locations..." : $"{Markers.Count} locations")" IsPlaceHolder="@(Markers.Count == 0)" IsEnabled="@(Markers.Count != 0)">
                        <Map Markers="@Markers" MarkerSelected="OnMarkerSelected" />
                    </MapToggle>
                </div>
                <div class="my-3">
                    <InlineMarkdownEdit Value="@Model.Text" PlaceHolder="No description..." ValueChanged="@(async value => await SaveTextAsync(value))" />
                </div>

                <div class="mb-3 timeline-narrow">
                    <Timeline DataGetter="@(offset => Api.GetBeingTimelineAsync(Model.Id, offset))" NoMoreText="@($"Here {Model.Name} started...")" />
                </div>
            </div>
        </PermissionContainer>
    </CascadingValue>

    <BeingIconPicker @ref="IconPicker" Value="@Model.Icon" Selected="@(async value => await SaveIconAsync(value))" />
}
