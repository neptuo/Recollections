@if (Count > 0)
{
    <div class="entry">
        <div class="body mb-4">
            <a href="@Navigator.UrlOnThisDay()" class="d-block text-decoration-none">
                <Alert Mode="@AlertMode.Info" CssClass="mb-0">
                    <Icon Identifier="history" CssClass="me-1" />
                    You have @Count @(Count == 1 ? "memory" : "memories") from this day in previous years.
                </Alert>
            </a>
        </div>
    </div>
}
