@inherits UserStateComponentBase

@if (BeforeContent != null || Entries.Count > 0)
{
    var index = 0;
    var lastYear = 0;
    <div class="timeline">
        @if (ShowYearSeparators)
        {
            <div class="separator sticky-top mb-3 d-inline-block">
                <div class="badge p-2 d-inline-block bg-secondary">
                    Now
                </div>
            </div>
        }

        <Gallery @ref="Gallery" Models="@GalleryItems" DataGetter="OnGetMediaDataAsync" OnOpenInfo="OnGalleryOpenInfoAsync" />
        @BeforeContent

        @if(Collapsible && Entries.Count > 5)
        {
            <div class="separator @(!IsCollapsed ? "mb-3" : "") badge p-2 d-inline-block bg-body-secondary position-relative top-0 z-1 cursor-pointer" style="margin-left: -6px;" @onclick="@(e => IsCollapsed = !IsCollapsed)">
                <Icon Identifier="comment-alt" CssClass="me-1" />
                @Entries.Count
@(Entries.Count > 1 ? "entries" : "entry")
            </div>
        }

        @if (!IsCollapsed)
        {
            @foreach (var entry in Entries)
            {
                if (ShowYearSeparators && entry.When.Year != lastYear)
                {
                    lastYear = entry.When.Year;
                    <div class="separator sticky-top mb-3 badge p-2 d-inline-block bg-secondary">
                        @lastYear
                    </div>
                }

                <div class="entry" data-entry-id="@entry.Id">
                    <div class="title">
                        <h3>@entry.When.ToString(ShowYearSeparators ? UiOptions.ShortDateFormat : UiOptions.DateFormat)</h3>
                    </div>
                    <div class="body">
                        <h2>
                            <a href="@Navigator.UrlEntryDetail(entry.Id)" data-entry-id="@entry.Id" data-entry-offset="@offset" onpointerdown="@(OnClick.HasDelegate ? null : "window.Timeline.StorePosition(this)")" onkeydown="@(OnClick.HasDelegate ? null : "window.Timeline.StorePositionOnKeyDown(this, event)")" @onclick="(() => OnEntryClicked(entry))" @onclick:preventDefault="@OnClick.HasDelegate">
                                @entry.Title
                            </a>
                        </h2>
                        <p>
                            @if (ShowStoryInfo && (!String.IsNullOrEmpty(entry.StoryTitle) || !String.IsNullOrEmpty(entry.ChapterTitle)))
                            {
                                <span class="information">
                                    <Icon Identifier="book" />

                                    @entry.StoryTitle
                                    @if (!String.IsNullOrEmpty(entry.ChapterTitle))
                                    {
                                        <span>
                                            - @entry.ChapterTitle
                                        </span>
                                    }
                                </span>
                            }

                            @if (entry.TextWordCount > 0)
                            {
                                <span class="information">
                                    <Icon Identifier="quote-right" />
                                    @entry.TextWordCount words
                                </span>
                            }

                            @if (entry.GpsCount > 0)
                            {
                                <span class="information">
                                    <Icon Prefix="fas" Identifier="location-arrow" />
                                    @entry.GpsCount
                                </span>
                            }

                            @if (entry.ImageCount > 0)
                            {
                                <span class="information">
                                    <Icon Identifier="image" />
                                    @entry.ImageCount
                                </span>
                            }

                            @if (entry.VideoCount > 0)
                            {
                                <span class="information">
                                    <Icon Identifier="film" />
                                    @entry.VideoCount
                                </span>
                            }

                            @if (entry.Beings != null)
                            {
                                foreach (var being in entry.Beings)
                                {
                                    <span class="information">
                                        <BeingIcon Identifier="@being.Icon" />
                                        @being.Name
                                    </span>
                                }
                            }

                            @if (UserState.UserId != entry.UserId)
                            {
                                <span class="information">
                                    <Icon Identifier="user" />
                                    @entry.UserName
                                </span>
                            }
                        </p>

                        @if (entry.PreviewMedia?.Count > 0)
                        {
                            <div class="row row-cols-3 row-cols-sm-4 row-cols-lg-6 g-2 mt-2 timeline-preview-media">
                                @for (var mediaIndex = 0; mediaIndex < entry.PreviewMedia.Count; mediaIndex++)
                                {
                                    var previewIndex = mediaIndex;
                                    var media = entry.PreviewMedia[previewIndex];

                                    <div class="col mt-0">
                                        <EntryMedia EntryId="@entry.Id" Image="@media.Image" Video="@media.Video" OnClick="@(() => OpenGalleryAsync(entry, previewIndex))">
                                            <ThumbnailContent>
                                                <span class="badge text-bg-dark position-absolute bottom-0 start-0 m-1 opacity-75">
                                                    <Icon Identifier="@(media.Video != null ? "film" : "image")" Prefix="fas" />
                                                </span>
                                            </ThumbnailContent>
                                        </EntryMedia>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                @if (index == Entries.Count - 3 && HasMore)
                {
                    <AutoloadNext Intersected="LoadMoreAsync" />
                }
                index++;
            }
        }
    </div>
}
