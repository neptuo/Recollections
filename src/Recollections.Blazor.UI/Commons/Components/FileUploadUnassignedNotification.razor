@inject FileUploader FileUploader
@implements IDisposable

@if (UnassignedFiles.Length > 0)
{
    <div class="container flex-nowrap sticky-top pb-2 bg-body file-progress-global">
        <div class="alert alert-secondary mb-0">
            <div class="d-flex align-items-center">
                @if (EntityType != null && EntityId != null)
                {
                    <button type="button" class="btn btn-sm btn-primary" @onclick="@OnUploadClickAsync">
                        Upload @UnassignedFiles.Length file@(UnassignedFiles.Length == 1 ? "" : "s") here
                    </button>
                }
                else
                {
                    <span @onclick="@Toggle" class="cursor-pointer">
                        @UnassignedFiles.Length file@(UnassignedFiles.Length == 1 ? "" : "s") ready. Open an entry to upload them.
                    </span>
                }

                <Icon
                    OnClick="@Toggle"
                    Identifier="@(IsExpanded ? "chevron-down" : "chevron-left")" 
                    CssClass="ms-auto cursor-pointer"
                />
            </div>
            @if (IsExpanded)
            {
                <div class="list-group mt-3">
                    @foreach (var file in UnassignedFiles)
                    {
                        <div class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                            <div class="flex-shrink-0" style="width: 4rem;">
                                @if (file.HasPreview && file.IsImage)
                                {
                                    <img src="@file.PreviewUrl" alt="@file.Name" class="img-fluid rounded border w-100" />
                                }
                                else if (file.HasPreview && file.IsVideo)
                                {
                                    <video src="@file.PreviewUrl" class="rounded border w-100" muted playsinline preload="metadata"></video>
                                }
                                else
                                {
                                    <div class="rounded border bg-body-secondary d-flex align-items-center justify-content-center text-secondary" style="aspect-ratio: 1 / 1;">
                                        <Icon Identifier="@(file.IsVideo ? "film" : "file")" Prefix="fas" />
                                    </div>
                                }
                            </div>
                            <span class="flex-grow-1 text-truncate">
                                <span class="d-block">@file.Name</span>
                                <small class="text-secondary">@Utils.FileSize(file.Size)</small>
                            </span>
                            <span>
                                <Icon Identifier="trash-alt" OnClick="@(() => DeleteStoredFileAsync(file))" CssClass="text-danger" />
                            </span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    bool IsExpanded = false;
    FileUploadToRetry[] UnassignedFiles = [];
    IDisposable currentUploadEntityRegistration;
    IDisposable storedFilesChangedRegistration;

    string EntityType;
    string EntityId;
    string Url;

    protected override async Task OnInitializedAsync()
    {
        currentUploadEntityRegistration = FileUploader.AddCurrentEntityListener(OnCurrentUploadEntityChanged);
        storedFilesChangedRegistration = FileUploader.AddStoredFilesChangedListener(OnStoredFilesChanged);
        await base.OnInitializedAsync();

        await RefreshUnassignedFilesAsync();
    }

    public void Dispose()
    {
        currentUploadEntityRegistration?.Dispose();
        storedFilesChangedRegistration?.Dispose();
    }

    private void Toggle()
        => IsExpanded = !IsExpanded;

    private void OnCurrentUploadEntityChanged(string entityType, string entityId, string url)
    {
        EntityType = entityType;
        EntityId = entityId;
        Url = url;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnStoredFilesChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshUnassignedFilesAsync();
            StateHasChanged();
        });
    }

    private async Task OnUploadClickAsync()
    {
        UnassignedFiles = [];
        await FileUploader.UploadUnassignedFilesToAsync(EntityType, EntityId, Url);
        await RefreshUnassignedFilesAsync();
        StateHasChanged();
    }

    async Task DeleteStoredFileAsync(FileUploadToRetry file)
    {
        await FileUploader.RemoveStoredFileAsync(file.Id);
        await RefreshUnassignedFilesAsync();
        StateHasChanged();
    }

    private async Task RefreshUnassignedFilesAsync()
    {
        bool hadFiles = UnassignedFiles.Length > 0;
        UnassignedFiles = await FileUploader.GetUnassignedSharedFilesAsync();

        if (UnassignedFiles.Length == 0)
            IsExpanded = false;
        else if (!hadFiles)
            IsExpanded = true;
    }
}
