@using Neptuo.Recollections.Accounts
@page "/notifications"
@layout Commons.Layouts.MainLayout
@inherits UserStateAuthenticatedComponentBase

<DocumentTitle Value="Notifications" />

<div class="beings">
    <Validation ErrorMessages="ErrorMessages" />

    @if (!String.IsNullOrEmpty(StatusMessage))
    {
        <div class="alert alert-success my-4" role="alert">
            <Icon Identifier="check" CssClass="me-1" />
            @StatusMessage
        </div>
    }

    @if (IsLoading)
    {
        <div class="alert alert-secondary my-4" role="alert">
            Loading notification settings...
        </div>
    }
    else
    {
        <form @onsubmit="SaveAsync">
            <div class="card my-4">
                <div class="card-body">
                    <h5 class="card-title">
                        <Icon Identifier="bell" CssClass="me-1" />
                        Notification preferences
                    </h5>
                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" id="notificationsEnabled" @bind="Model.IsEnabled" />
                        <label class="form-check-label" for="notificationsEnabled">Enable notifications</label>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label class="form-label" for="preferredHour">Preferred daily time</label>
                            <select class="form-select" id="preferredHour" @bind="Model.PreferredHour">
                                @for (int hour = 0; hour < 24; hour++)
                                {
                                    <option value="@hour">@($"{hour:00}:00")</option>
                                }
                            </select>
                            <div class="form-text">
                                The API will send at most one digest per day after this local hour.
                            </div>
                        </div>
                        <div class="col-md-6 mt-3 mt-md-0">
                            <label class="form-label" for="timeZoneId">Time zone</label>
                            <div class="input-group">
                                <input class="form-control" id="timeZoneId" type="text" placeholder="Europe/Prague" @bind="Model.TimeZoneId" />
                                <button type="button" class="btn btn-outline-secondary" @onclick="UseBrowserTimeZoneAsync" disabled="@IsBusy">
                                    Use browser timezone
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card my-4">
                <div class="card-body">
                    <h5 class="card-title">
                        <Icon Identifier="stream" CssClass="me-1" />
                        New entries from connections
                    </h5>
                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" id="newEntriesEnabled" @bind="Model.NewEntries.IsEnabled" />
                        <label class="form-check-label" for="newEntriesEnabled">Notify me about new entries from my active connections</label>
                    </div>
                </div>
            </div>

            <div class="card my-4">
                <div class="card-body">
                    <h5 class="card-title">
                        <Icon Identifier="mobile-alt" CssClass="me-1" />
                        Browser push subscription
                    </h5>

                    @if (!IsPushSupported)
                    {
                        <div class="alert alert-warning mt-3" role="alert">
                            This browser does not support Web Push notifications.
                        </div>
                    }
                    else if (String.IsNullOrWhiteSpace(Model.PushPublicKey))
                    {
                        <div class="alert alert-warning mt-3" role="alert">
                            Push delivery is not configured on the server yet.
                        </div>
                    }
                    else
                    {
                        <div class="mt-3">
                            <div>
                                Browser permission:
                                <strong>@BrowserPermissionLabel</strong>
                            </div>
                            <div>
                                This browser:
                                <strong>@(HasBrowserSubscription ? "Subscribed" : "Not subscribed")</strong>
                            </div>
                            <div>
                                Any active subscription on your account:
                                <strong>@(Model.HasSubscription ? "Yes" : "No")</strong>
                            </div>
                        </div>

                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <button type="button" class="btn btn-primary" @onclick="SubscribeAsync" disabled="@(!CanSubscribe)">
                                <Icon Identifier="bell" CssClass="me-1" />
                                Enable on this browser
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="UnsubscribeAsync" disabled="@(!HasBrowserSubscription || IsBusy)">
                                <Icon Identifier="bell-slash" CssClass="me-1" />
                                Disable on this browser
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div class="text-end my-4">
                <button class="btn btn-primary" disabled="@IsBusy">
                    <Icon Identifier="save" CssClass="me-1" />
                    Save settings
                </button>
            </div>
        </form>
    }
</div>
