@code
{
    public static RenderFragment FileSize(long? size)
    {
        return @<span class="text-nowrap">@FileSizeText(size)</span>;
    }

    public static string FileSizeText(long? bytes)
    {
        if (bytes == null)
            return null;

        const long KB = 1024;
        const long MB = KB * 1024;
        const long GB = MB * 1024;

        if (bytes < KB)
            return $"{bytes} B";
        else if (bytes < MB)
            return $"{bytes / KB} KB";
        else if (bytes < GB)
            return $"{bytes / MB} MB";
        else
            return $"{((double)bytes / GB):F1} GB";
    }
}
